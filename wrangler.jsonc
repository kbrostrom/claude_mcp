{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "github-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "6ac606546d6e4ecd822fc71aeedc47bd"
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "OAUTH_PROVIDER_NAME": "GitHub MCP"
  }
}
